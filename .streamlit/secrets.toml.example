# Example secrets file for TRADEON.
#
# This file is a TEMPLATE. Copy it to `.streamlit/secrets.toml` (which is
# git-ignored) and fill in any values you actually want to use locally.
#
# On Streamlit Community Cloud, paste these same key/value pairs into the
# app's "Secrets" panel in the Streamlit Cloud dashboard - do NOT commit
# the real `secrets.toml` to the repo.

# Optional - if you want to require a password before the app loads.
# (Used by simple inline auth gate; not currently enforced by app.py.)
# app_password = "change-me"

# yfinance does not need credentials, so no API keys are required by default.
