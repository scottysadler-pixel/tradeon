# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
venv/
.venv/
env/

# Local data cache.
# We DO want to commit the bundled cache so Streamlit Cloud cold-starts
# instantly instead of refetching 20 years of history for every symbol.
# The nightly GitHub Action (.github/workflows/refresh-cache.yml) keeps
# data_cache/*.parquet up to date.
# Anything else under data_cache/ (logs, scratch files, manual exports)
# stays ignored.
data_cache/*
!data_cache/.gitkeep
!data_cache/*.parquet
!data_cache/MANIFEST.json

# Pipeline result pickles (disk-persistent layer of the @st.cache_data
# tier). Each deploy generates its own — they're keyed by CACHE_VERSION,
# so stale ones across versions are auto-rejected. No need to commit them.
data_cache/pipeline/

# Stray parquet files anywhere else in the tree are still ignored.
/*.parquet
**/scratch_*.parquet

# Streamlit
.streamlit/secrets.toml

# IDE
.vscode/
.idea/

# OS
Thumbs.db
.DS_Store

# Local user settings
user_settings.json
